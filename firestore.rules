rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin list: set in Console. Only used in rules (no client read needed).
    match /config/admins {
      allow read, write: if false;
    }
    // Applications: allow public read (needed for duplicate checking & 7-day re-application check); 
    // allow public create; only admins can update/delete.
    match /applications/{appId} {
      allow create: if true;
      allow read: if true; 
      allow update, delete: if request.auth != null;
    }
    // Messages: anyone can create; only admins can read.
    match /messages/{msgId} {
      allow create: if true;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
